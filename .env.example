# Copy this to .env and fill in your values
# Never commit .env to git

# --- Required ---
OPENAI_API_KEY=sk-...          # Used for Whisper transcription
ANTHROPIC_API_KEY=sk-ant-...   # Used for analysis, synthesis, profile extraction

# --- Set automatically by docker-compose (do not change) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/customer_research
REDIS_URL=redis://redis:6379

# --- Optional: S3 for file storage (falls back to local disk) ---
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Optional: override defaults ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500
